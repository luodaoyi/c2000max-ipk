TARGET_DEVICE_NAME=HC-WT9303
TARGET_BOARD_NAME=HCMT7987-SNSD
TARGET_FIRMWARE_RELEASE=21.02-SNAPSHOT
TARGET_FIRMWARE_REVISION=2.1.2.n0.c1
TARGET_FIRMWARE_TARGET=mediatek/mt7987
TARGET_FIRMWARE_ARCH=aarch64_cortex-a53
TARGET_FIRMWARE_KERNEL=5.4.281
TARGET_FIREWALL_BACKEND=iptables

# 说明：
# - 当前设备固件是厂商定制的 21.02-SNAPSHOT（mt7987 / 5.4.281）
# - 本仓库只构建“用户态”补充包，不构建任何 kmod
# - SDK 仍使用官方 21.02.7 aarch64_cortex-a53，用于编译与当前设备 ABI 兼容的用户态 IPK
OPENWRT_VERSION=21.02.7
OPENWRT_ARCH=aarch64_cortex-a53
SDK_IMAGE=ghcr.io/openwrt/sdk:aarch64_cortex-a53-21.02.7

PACKAGE_SOURCE_URL=https://github.com/shidahuilang/openwrt-package.git
PACKAGE_SOURCE_REF=Lede
CUSTOM_FEED_NAME=shidahuilang
